{
  "name": "@wolfstar/plugin-api",
  "version": "1.1.1",
  "description": "Plugin for @wolfstar/http-framework exposing a standalone REST API server (routes, middlewares, router)",
  "keywords": [
    "api",
    "discord",
    "http-framework",
    "plugin",
    "rest",
    "wolfstar"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wolfstar-project/stars-components.git",
    "directory": "packages/plugin-api"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/register.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src --fix",
    "test": "vitest run",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@sapphire/pieces": "^4.4.1",
    "@vladfrangu/async_event_emitter": "^2.4.7"
  },
  "devDependencies": {
    "@wolfstar/http-framework": "^3.0.0"
  },
  "peerDependencies": {
    "@wolfstar/http-framework": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
